# === Cloudflare R2 (S3-compatible storage) ===
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_ACCOUNT_ID=your_cloudflare_account_id

# === Weights & Biases ===
WANDB_API_KEY=your_wandb_api_key

# === HuggingFace (for gated model downloads) ===
HF_TOKEN=your_huggingface_token

# === Sigil author key (hex-encoded 32-byte Ed25519 private key seed) ===
# Generate with: python -c "from sigil_watermark import generate_author_keys; k=generate_author_keys(); print(k.private_key.hex())"
SIGIL_ARTIST_PRIVATE_KEY=your_hex_encoded_private_key

# === R2 Bucket name ===
R2_BUCKET=sigil-experiments

# === RunPod ===
# Get your API key from: https://www.runpod.io/console/user/settings
RUNPOD_API_KEY=your_runpod_api_key

# RunPod defaults (optional overrides)
# DEFAULT_REGION=US-TX-3
# DEFAULT_GPU_TYPE=NVIDIA A100 80GB PCIe
# DEFAULT_GPU_COUNT=1
# DEFAULT_CLOUD_TYPE=SECURE
# DEFAULT_CONTAINER_DISK_GB=50
# DEFAULT_VOLUME_GB=200
